    "seoFiles": {
      "robots.txt": {
        "description": "Instruções para crawlers e referência ao sitemap",
        "essencial": true,
        "location": "Raiz do domínio (/robots.txt)"
      },
      "sitemap.xml": {
        "description": "Mapa do site para SEO",
        "essencial": true,
