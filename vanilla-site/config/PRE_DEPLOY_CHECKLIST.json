      },
      ".htaccess": {
        "description": "Configurações Apache (gzip, cache, security headers)",
        "essencial": true,
        "location": "Raiz do domínio /.htaccess",
        "requires": "Apache com mod_rewrite habilitado"
      }
    },
    "configurations": {
      "https": {
        "status": "REQUERIDO",
        "description": "Certificado SSL/TLS válido",
        "impact": "SEO e segurança"
      },
      "domainSetup": {
        "status": "REQUERIDO",
        "description": "Apontar domínio para servidor",
        "steps": [
          "Configurar DNS A record para IP do servidor",
          "Aguardar propagação DNS (até 48h)",
          "Verificar acesso via navegador"
        ]
      },
      "gzipCompression": {
        "status": "ATIVO",
        "description": "Compressão automática via .htaccess",
        "formats": ["html", "css", "js", "json", "svg"]
      },
      "browserCache": {
        "status": "ATIVO",
        "description": "Cache configurado via .htaccess",
        "rules": {
          "images": "1 year",
          "fonts": "1 year",
          "css_js": "1 month",
          "html": "1 day"
        }
      },
      "securityHeaders": {
        "status": "ATIVO",
        "headers": [
          "X-Frame-Options: SAMEORIGIN",
          "X-Content-Type-Options: nosniff",
          "X-XSS-Protection: 1; mode=block",
          "Referrer-Policy: no-referrer-when-downgrade",
          "Permissions-Policy: geolocation=(), microphone=(), camera=()"
        ]
      }
    },
